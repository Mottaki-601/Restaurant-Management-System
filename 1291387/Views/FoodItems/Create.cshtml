@model _1291387.Models.FoodItem

@{
    ViewBag.Title = "Add New Food";
}

<style>
    .center-wrapper {
        min-height: 85vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .form-container {
        background: #ffffff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        border-top: 5px solid #ff6b6b; 
        width: 100%;
        max-width: 500px; 
    }

    .form-header {
        text-align: center;
        margin-bottom: 30px;
        color: #333;
    }

        .form-header h2 {
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 24px;
            margin-top: 0;
        }

        .form-header p {
            color: #777;
            font-size: 14px;
        }

    .custom-input {
        height: 50px;
        border-radius: 25px;
        padding-left: 20px;
        border: 1px solid #ddd;
        transition: all 0.3s ease;
        max-width: 100%;
    }

        .custom-input:focus {
            border-color: #ff6b6b;
            box-shadow: 0 0 8px rgba(255, 107, 107, 0.3);
            outline: none;
        }

    .btn-custom {
        background: linear-gradient(45deg, #ff6b6b, #ff8e53);
        border: none;
        color: white;
        height: 50px;
        border-radius: 25px;
        font-weight: bold;
        letter-spacing: 1px;
        transition: transform 0.2s, box-shadow 0.2s;
        width: 100%;
        margin-top: 10px;
    }

        .btn-custom:hover {
            transform: translateY(-2px); 
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.4);
            color: white;
        }

    .back-link {
        text-align: center;
        margin-top: 25px;
    }

        .back-link a {
            color: #999;
            text-decoration: none;
            font-weight: 600;
            font-size: 13px;
            transition: color 0.3s;
        }

            .back-link a:hover {
                color: #ff6b6b;
            }
</style>

<div class="center-wrapper">

    <div class="form-container">
        <div class="form-header">
            <h2>Create New Item</h2>
            <p>Add a delicious new item to the menu</p>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-horizontal">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="form-group">
                    <div class="col-md-12">
                        @Html.LabelFor(model => model.ItemName, htmlAttributes: new { @class = "control-label", @style = "text-align:left; margin-bottom:8px; color:#555;" })
                        @Html.EditorFor(model => model.ItemName, new { htmlAttributes = new { @class = "form-control custom-input", @placeholder = "e.g. Spicy Chicken Burger" } })
                        @Html.ValidationMessageFor(model => model.ItemName, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-12">
                        <button type="submit" class="btn btn-default btn-custom">
                            <span class="glyphicon glyphicon-plus-sign"></span> Save Item
                        </button>
                    </div>
                </div>
            </div>
        }

        <div class="back-link">
            @Html.ActionLink("← Back to List", "Index")
        </div>
    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}