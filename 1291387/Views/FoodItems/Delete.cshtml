@model _1291387.Models.FoodItem

@{
    ViewBag.Title = "Delete Item";
}

<div class="container" style="margin-top: 50px;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h3><i class="fa fa-exclamation-triangle"></i> Delete Confirmation</h3>
                </div>
                <div class="card-body text-center">
                    <h4 class="card-title text-danger">Are you sure you want to delete this?</h4>
                    <p class="card-text text-muted">This action cannot be undone.</p>
                    <hr />

                    <div class="item-details p-3 mb-3" style="background-color: #f8d7da; border-radius: 10px;">
                        <h2 class="display-6">@Html.DisplayFor(model => model.ItemName)</h2>
                        <small class="text-muted">@Html.DisplayNameFor(model => model.ItemName)</small>
                    </div>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-actions no-color mt-4">
                            <button type="submit" class="btn btn-danger btn-lg px-4">
                                <i class="fa fa-trash"></i> Delete Permanently
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg px-4">
                                <i class="fa fa-arrow-left"></i> Cancel
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>