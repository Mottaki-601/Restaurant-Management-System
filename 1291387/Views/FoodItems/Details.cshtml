@model _1291387.Models.FoodItem

@{
    ViewBag.Title = "Item Details";
}

<style>
    .details-wrapper {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .details-card {
        background: #ffffff;
        width: 100%;
        max-width: 500px;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        border: 1px solid #eee;
    }

    .details-header {
        background: linear-gradient(135deg, #6c5ce7, #a29bfe);
        padding: 40px 20px;
        text-align: center;
        color: white;
    }

        .details-header .icon-box {
            background: rgba(255, 255, 255, 0.2);
            width: 70px;
            height: 70px;
            line-height: 70px;
            border-radius: 50%;
            display: inline-block;
            font-size: 30px;
            margin-bottom: 15px;
        }

        .details-header h2 {
            margin: 0;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-size: 20px;
        }

    .details-body {
        padding: 40px;
        text-align: center;
    }

    .info-label {
        color: #b2bec3;
        text-transform: uppercase;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 2px;
        margin-bottom: 10px;
    }

    .info-value {
        color: #2d3436;
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 30px;
    }

    .details-footer {
        display: flex;
        border-top: 1px solid #f1f1f1;
    }

    .footer-btn {
        flex: 1;
        text-align: center;
        padding: 15px;
        text-decoration: none !important;
        font-weight: 700;
        font-size: 14px;
        transition: 0.3s;
    }

    .btn-edit-action {
        background: #fff;
        color: #6c5ce7;
    }

        .btn-edit-action:hover {
            background: #f8f9ff;
            color: #4834d4;
        }

    .btn-back-action {
        background: #fdfdfd;
        color: #636e72;
        border-left: 1px solid #f1f1f1;
    }

        .btn-back-action:hover {
            background: #f1f2f6;
            color: #2d3436;
        }
</style>

<div class="details-wrapper">
    <div class="details-card">

        <div class="details-header">
            <div class="icon-box">
                <span class="glyphicon glyphicon-info-sign"></span>
            </div>
            <h2>Item Overview</h2>
        </div>

        <div class="details-body">
            <div class="info-label">
                @Html.DisplayNameFor(model => model.ItemName)
            </div>
            <div class="info-value">
                @Html.DisplayFor(model => model.ItemName)
            </div>
        </div>

        <div class="details-footer">
            <a href="@Url.Action("Edit", new { id = Model.FoodItemId })" class="footer-btn btn-edit-action">
                <i class="glyphicon glyphicon-pencil"></i> Edit Item
            </a>
            <a href="@Url.Action("Index")" class="footer-btn btn-back-action">
                <i class="glyphicon glyphicon-th-list"></i> Back to List
            </a>
        </div>

    </div>
</div>