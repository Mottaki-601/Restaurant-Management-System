@model IEnumerable<_1291387.Models.FoodItem>

@{
    ViewBag.Title = "Fast-Food Items";
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 40px 0;
        border-bottom: 2px solid #eee;
        padding-bottom: 20px;
    }

        .page-header h2 {
            font-weight: 700;
            color: #2d3436;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .btn-add {
        background: linear-gradient(45deg, #00b894, #55efc4);
        color: white !important;
        padding: 10px 25px;
        border-radius: 30px;
        text-decoration: none !important;
        font-weight: bold;
        box-shadow: 0 4px 15px rgba(0, 184, 148, 0.3);
        transition: 0.3s;
    }

        .btn-add:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(0, 184, 148, 0.4);
        }

    .food-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 25px;
        padding: 10px 0;
    }

    .food-card {
        background: #fff;
        border-radius: 15px;
        padding: 25px;
        position: relative;
        transition: all 0.3s ease;
        border: 1px solid #f1f1f1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

        .food-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            border-color: #ff6b6b;
        }

    .item-icon {
        font-size: 30px;
        margin-bottom: 15px;
        color: #ff6b6b;
    }

    .food-name {
        font-size: 20px;
        font-weight: 700;
        color: #2d3436;
        margin-bottom: 20px;
    }

    .card-actions {
        display: flex;
        gap: 10px;
        border-top: 1px solid #eee;
        padding-top: 15px;
    }

    .action-link {
        font-size: 13px;
        font-weight: 600;
        text-decoration: none !important;
        padding: 5px 12px;
        border-radius: 5px;
        transition: 0.2s;
    }

    .edit-link {
        color: #0984e3;
        background: #e1f5fe;
    }

        .edit-link:hover {
            background: #0984e3;
            color: white;
        }

    .details-link {
        color: #6c5ce7;
        background: #efeeff;
    }

        .details-link:hover {
            background: #6c5ce7;
            color: white;
        }

    .delete-link {
        color: #d63031;
        background: #ffebee;
    }

        .delete-link:hover {
            background: #d63031;
            color: white;
        }
</style>

<div class="container">
    <div class="page-header">
        <h2>🍔 Menu Gallery</h2>
        <a href="@Url.Action("Create")" class="btn-add">
            <span class="glyphicon glyphicon-plus"></span> Add New Food
        </a>
    </div>

    <div class="food-grid">
        @foreach (var item in Model)
        {
            <div class="food-card">
                <div>
                    <div class="item-icon">
                        <span class="glyphicon glyphicon-cutlery"></span>
                    </div>
                    <div class="food-name">
                        @Html.DisplayFor(modelItem => item.ItemName)
                    </div>
                </div>

                <div class="card-actions">
                    <a href="@Url.Action("Edit", new { id=item.FoodItemId })" class="action-link edit-link">Edit</a>
                    <a href="@Url.Action("Details", new { id=item.FoodItemId })" class="action-link details-link">View</a>
                    <a href="@Url.Action("Delete", new { id=item.FoodItemId })" class="action-link delete-link">Delete</a>
                </div>
            </div>
        }
    </div>
</div>