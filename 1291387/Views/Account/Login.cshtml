
@using System.Web
@using Microsoft.Owin.Security
@using _1291387.Models
@model LoginViewModel
@{
    ViewBag.Title = "Welcome Back";
}

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); 
        min-height: 100vh;
    }

    .login-container {
        margin-top: 50px;
        margin-bottom: 50px;
    }

    .login-card {
        background: #ffffff;
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1); 
        overflow: hidden;
        padding: 40px;
    }

    .login-header h2 {
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
    }

    .login-header p {
        color: #777;
        font-size: 0.9rem;
    }

    .form-control-custom {
        border-radius: 50px; 
        padding: 12px 20px;
        background-color: #f8f9fa;
        border: 1px solid #eee;
        transition: all 0.3s;
    }

        .form-control-custom:focus {
            background-color: #fff;
            border-color: #6c5ce7; 
            box-shadow: 0 0 0 0.2rem rgba(108, 92, 231, 0.1);
        }

    .btn-login {
        border-radius: 50px;
        padding: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
        background: linear-gradient(to right, #6c5ce7, #a29bfe); 
        border: none;
        color: white;
        width: 100%;
        transition: transform 0.2s;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);
            color: white;
        }

    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 20px 0;
        color: #aaa;
    }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #eee;
        }

        .divider:not(:empty)::before {
            margin-right: .25em;
        }

        .divider:not(:empty)::after {
            margin-left: .25em;
        }

    .register-link {
        text-align: center;
        margin-top: 20px;
        font-size: 0.9rem;
    }

        .register-link a {
            color: #6c5ce7;
            font-weight: 600;
            text-decoration: none;
        }
</style>

<main aria-labelledby="title" class="container login-container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="login-card">

                <div class="login-header text-center">
                    <h2>@ViewBag.Title</h2>
                    <p>Please enter your details to sign in.</p>
                </div>

                <section id="loginForm">
                    @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger small text-center" })

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.Email, new { @class = "form-label fw-bold ml-2" })
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-custom", placeholder = "name@example.com" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small ml-2" })
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.Password, new { @class = "form-label fw-bold ml-2" })
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-custom", placeholder = "********" })
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small ml-2" })
                        </div>

                        <div class="form-group mb-4">
                            <div class="custom-control custom-checkbox ml-2">
                                @Html.CheckBoxFor(m => m.RememberMe, new { @class = "custom-control-input" })
                                @Html.LabelFor(m => m.RememberMe, new { @class = "custom-control-label" })
                            </div>
                        </div>

                        <div class="form-group">
                            <input type="submit" value="Log In" class="btn btn-login" />
                        </div>

                        <div class="register-link">
                            Don't have an account?
                            @Html.ActionLink("Create one now", "Register")
                        </div>
                    }
                </section>

                @{
                    var loginProviders = Context.GetOwinContext().Authentication.GetExternalAuthenticationTypes();
                    if (loginProviders.Count() > 0)
                    {
                        <div class="divider">OR</div>
                        <section id="socialLoginForm" class="text-center">
                            @Html.Partial("_ExternalLoginsListPartial", new ExternalLoginListViewModel { ReturnUrl = ViewBag.ReturnUrl })
                        </section>
                    }
                }
            </div>
        </div>
    </div>
</main>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}