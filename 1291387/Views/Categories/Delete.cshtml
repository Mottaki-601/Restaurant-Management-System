@model _1291387.Models.Category

@{
    ViewBag.Title = "Delete Category";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-lg">
                <div class="card-header bg-danger text-white text-center py-4">
                    <i class="fa fa-exclamation-circle fa-4x mb-2"></i>
                    <h2 class="mb-0">Confirm Deletion</h2>
                </div>

                <div class="card-body text-center p-5">
                    <h4 class="text-secondary">Are you sure you want to delete this category?</h4>
                    <p class="text-danger mb-4"><strong>Warning:</strong> This action cannot be undone and may affect related food items.</p>

                    <div class="p-4 bg-light rounded-pill border mb-4">
                        <span class="text-muted small d-block text-uppercase">Category Name</span>
                        <h3 class="text-dark mb-0">@Html.DisplayFor(model => model.CategoryName)</h3>
                    </div>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <div class="d-grid gap-2 d-md-block">
                            <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm">
                                <i class="fa fa-trash"></i> Permanently Delete
                            </button>
                            <div class="mt-3">
                                <a href="@Url.Action("Index")" class="btn btn-link text-muted">
                                    <i class="fa fa-undo"></i> No, take me back
                                </a>
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-transparent text-center border-0 pb-4">
                    <small class="text-muted">ID Reference: #@Model.CategoryId</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 20px;
        overflow: hidden;
    }

    .btn-lg {
        border-radius: 50px;
    }

    .bg-light {
        background-color: #fff5f5 !important;
        border: 1px dashed #dc3545;
    }
</style>